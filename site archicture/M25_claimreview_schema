"""
Factor 25: ClaimReview Schema

Checks whether ClaimReview schema exists.
"""

import requests
import json
from bs4 import BeautifulSoup


def check_claimreview_schema(context):

    url = context["url"]

    result = {
        "factor": "25 - ClaimReview Schema",
        "claimreview_found": False,
        "reviewed_claim": None,
        "status": "Failed"
    }

    try:

        response = requests.get(
            url,
            headers={"User-Agent": "Mozilla/5.0"},
            timeout=10
        )

        response.raise_for_status()

        soup = BeautifulSoup(response.text, "html.parser")

        scripts = soup.find_all(
            "script",
            type="application/ld+json"
        )

        for script in scripts:

            if not script.string:
                continue

            try:
                data = json.loads(script.string)
            except:
                continue

            if not isinstance(data, list):
                data = [data]

            for item in data:

                if item.get("@type") == "ClaimReview":

                    result["claimreview_found"] = True

                    result["reviewed_claim"] = item.get("claimReviewed")

        if result["claimreview_found"]:
            result["status"] = "Success"

        return result

    except Exception as error:

        result["error"] = str(error)

        return result